# Copy this file to the EC2 host as minimal/.env.poly and fill real values there.
# Do not commit the filled file.

# Production live trading requires POLY_ALLOW_LIVE_ORDERS=true.
# Non-transactional smoke tests should use MINIMAL_DRY_RUN_ORDERS=true instead;
# dry-run mode never POSTs /order or DELETEs /orders.
POLY_ALLOW_LIVE_ORDERS=true
# MINIMAL_DRY_RUN_ORDERS=false
POLY_ALLOW_UNTRACKED_SELL=false

# Prefer a private key and let the bot derive API credentials at startup.
POLY_PK=0xREPLACE_WITH_PRIVATE_KEY
POLY_FUNDER=
POLY_CLOB_HOST=https://clob.polymarket.com
POLY_CHAIN_ID=137
POLY_SIG_TYPE=0

# Optional: provide API credentials directly instead of deriving them.
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Market/signal.
# MARKET_STRIKE / MINIMAL_STRIKE are kept only as a fallback used until the
# bot discovers the active market and pulls the strike from gamma metadata
# (or anchors it from buffered Binance microprices for direction-only
# markets — see "Strike Anchoring" in docs/README.md). Once context is in,
# the engine ignores these values.
MARKET_STRIKE=0
MINIMAL_STRIKE=0
MINIMAL_MAX_ASK=0.60
MINIMAL_MIN_BUY_LIMIT=0.10
MINIMAL_MAX_BUY_LIMIT=0.60
MINIMAL_USDC_PER_TRADE=10
MINIMAL_MIN_SIZE=0.01
MINIMAL_ENTRY_ORDER_TYPE=FAK
MINIMAL_EXIT_ORDER_TYPE=FAK
MINIMAL_ALLOW_RESTING_ORDERS=false
MINIMAL_REQUIRE_CALIBRATED_MODEL=true
# MINIMAL_SIGNAL_MODEL_PATH=/home/ubuntu/poly-buy-sell/minimal/state/signal_model.json

# Binance authenticated SBE market-data stream. Required by
# wss://stream-sbe.binance.com/ws; without this the bot receives no Binance
# ticks and therefore no BUY signals.
BINANCE_SBE_API_KEY=REPLACE_WITH_BINANCE_SBE_API_KEY

# Binance/Polymarket basis diagnostics — TELEMETRY ONLY since the strike is
# now anchored from slug-time Binance microprices (or Gamma when present).
# These values DO NOT influence the signal threshold. Kept only for the
# basis-vs-quote diagnostic file.
MINIMAL_BINANCE_BASIS_USD=0.0
MINIMAL_BASIS_EMA_ALPHA=0.05
MINIMAL_BASIS_MID_TOL=0.05
MINIMAL_BASIS_MIN_TTE_US=30000000
MINIMAL_BASIS_SAVE_INTERVAL_S=60
# Optional: override basis-state file path.
# MINIMAL_BASIS_STATE_PATH=/var/lib/minimal/basis.json

# Hot-path observability is OFF by default. Turn on only when debugging.
# MINIMAL_DEBUG_USER_CHANNEL=true

# Startup and lifecycle. Historical startup positions are ignored; only
# current-run bot-owned orders/trades enter the local tracker. Startup still
# fails closed on existing open CLOB orders because an old resting order could
# fill during this run and create invisible inventory.
# MINIMAL_ALLOW_DIRTY_START=false
MINIMAL_CANCEL_INTERVAL_S=0.25
MINIMAL_CANCEL_STALE_ORDER_S=2.0
MINIMAL_EXIT_INTERVAL_S=0.05

# Quote freshness and decision guards.
MINIMAL_MAX_QUOTE_AGE_NS=250000000
MINIMAL_DECISION_MAX_QUOTE_AGE_US=250000
# No new BUY entries inside the final 45 seconds before market expiry.
# This value is required; live startup fails closed if it is absent.
MINIMAL_DECISION_MIN_TTE_US=45000000
MINIMAL_DECISION_MIN_STRENGTH=3.0
MINIMAL_DECISION_MIN_EDGE=0.0

# Probabilistic signal scaling (Brownian barrier-cross with order-flow tilts).
# Defaults are intentionally conservative — set MINIMAL_PROB_USE_LEGACY=true
# to fall back to the legacy strength-based heuristic.
MINIMAL_PROB_ALPHA_OFI=0.0
MINIMAL_PROB_BETA_IMB=0.0
MINIMAL_PROB_SIGMA_SCALE=1.5
MINIMAL_PROB_SIGMA_FLOOR_USD=5.0
MINIMAL_PROB_FLOOR=0.02
MINIMAL_PROB_CEIL=0.98
MINIMAL_PROB_MIN_PROB=0.55
MINIMAL_PROB_MAX_TTE_US=600000000
MINIMAL_PROB_USE_LEGACY=false

# Exit policy.
MINIMAL_TAKE_PROFIT_BPS=1200
MINIMAL_STOP_LOSS_BPS=1800
MINIMAL_MAX_HOLD_US=0
MINIMAL_FORCE_EXIT_TTE_US=10000000
MINIMAL_EXIT_MAX_QUOTE_AGE_US=250000
MINIMAL_EXIT_MIN_BID=0.01

# HTTP/runtime. Order POSTs use a tighter per-request timeout (1.0s total)
# inside FastOrderSubmitter; this session-level timeout is the fallback for
# auth and gamma calls.
POLY_HTTP_TIMEOUT_S=3.0
POLY_HTTP_DNS_TTL_S=600
POLY_HTTP_KEEPALIVE_S=75.0
POLY_HTTP_CONN_LIMIT=8
POLY_HTTP_CONN_LIMIT_PER_HOST=8
MINIMAL_LOG_LEVEL=WARNING
